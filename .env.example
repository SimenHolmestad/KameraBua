# CameraHub settings (.env)
# Environment variables are prefixed with CAMERAHUB_ and use __ for nesting.

# General
CAMERAHUB_STATIC_FOLDER_NAME=static

# Albums
CAMERAHUB_ALBUMS__FORCED_ALBUM=
CAMERAHUB_ALBUMS__ALBUMS_DIR=backend/static/albums

# QR codes
CAMERAHUB_QR_CODES__USE_CENTER_IMAGES=true

# Wifi QR code (required fields if enabled)
CAMERAHUB_WIFI_QR_CODE__ENABLED=false
CAMERAHUB_WIFI_QR_CODE__WIFI_NAME=
CAMERAHUB_WIFI_QR_CODE__PROTOCOL=
CAMERAHUB_WIFI_QR_CODE__PASSWORD=
CAMERAHUB_WIFI_QR_CODE__DESCRIPTION=

# Camera
CAMERAHUB_CAMERA__CAMERA_TYPE=dummy
CAMERAHUB_CAMERA__VERBOSE_ERRORS=true

# Dummy config (ikke nødvendig, brukes til testing)
CAMERAHUB_CAMERA__DUMMY_CONFIG__WIDTH=1200
CAMERAHUB_CAMERA__DUMMY_CONFIG__HEIGHT=800
CAMERAHUB_CAMERA__DUMMY_CONFIG__NUMBER_OF_CIRCLES=80
CAMERAHUB_CAMERA__DUMMY_CONFIG__MIN_CIRCLE_RADIUS=30
CAMERAHUB_CAMERA__DUMMY_CONFIG__MAX_CIRCLE_RADIUS=80
CAMERAHUB_CAMERA__DUMMY_CONFIG__SHOULD_FAIL=false
CAMERAHUB_CAMERA__DUMMY_CONFIG__ERROR_MESSAGE=This is a test error message
