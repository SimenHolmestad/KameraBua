# CameraHub settings (.env)
# Environment variables are prefixed with CAMERAHUB_ and use __ for nesting.

# General
CAMERAHUB_STATIC_FOLDER_NAME=static

# Albums
CAMERAHUB_ALBUMS__FORCED_ALBUM=
CAMERAHUB_ALBUMS__ALBUMS_DIR=backend/static/albums

# QR codes
CAMERAHUB_QR_CODES__USE_CENTER_IMAGES=true

# Wifi QR code (required fields if enabled)
CAMERAHUB_WIFI_QR_CODE__ENABLED=false
CAMERAHUB_WIFI_QR_CODE__WIFI_NAME=
CAMERAHUB_WIFI_QR_CODE__PROTOCOL=
CAMERAHUB_WIFI_QR_CODE__PASSWORD=
CAMERAHUB_WIFI_QR_CODE__DESCRIPTION=

# Camera
CAMERAHUB_CAMERA__MODULE=dummy
CAMERAHUB_CAMERA__OPTIONS={}
CAMERAHUB_CAMERA__MODULES={}
